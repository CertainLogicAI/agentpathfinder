{
  "schemaVersion": "2024-v2",
  "id": "certainlogicai.agentpathfinder",
  "displayName": "AgentPathfinder",
  "version": "1.2.1",
  "description": "Open-source task router for AI agents. Now includes Brain-First query optimization, Hallucination Guard, and Task Tracking — the Trinity Stack.",
  "repository": "https://github.com/CertainLogicAI/agentpathfinder",
  "entrypoints": {
    "cli": {
      "command": [
        "python3",
        "-m",
        "agentpathfinder"
      ]
    }
  },
  "exports": {
    "trinity_stack": "agentpathfinder.trinity_stack:activate",
    "brain_hook": "agentpathfinder.brain_hook:activate_brain_first",
    "brain_skill": "agentpathfinder.brain_skill:CertainLogicBrainSkill",
    "task_tracking": "agentpathfinder.trinity_stack:start_task"
  },
  "tags": [
    "productivity",
    "open-source",
    "trust",
    "cost-optimization",
    "tamper-evident"
  ],
  "license": "MIT",
  "author": {
    "name": "CertainLogic",
    "url": "https://github.com/CertainLogicAI"
  },
  "safety": "SAFETY.md"
}
